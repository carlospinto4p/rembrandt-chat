{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-python.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-tests.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-chained-commands.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(uv sync:*)",
      "Bash(uv run:*)",
      "Bash(uv pip install:*)",
      "Bash(ruff:*)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git push)",
      "Bash(git rm:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(tree:*)"
    ],
    "deny": [
      "Read(credentials/**)",
      "Read(.env)"
    ]
  }
}
