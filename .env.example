# Required — Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Optional — path to a base vocabulary CSV file.
# On first run, if the words table is empty, this file is imported
# automatically. Leave blank or remove to skip.
BASE_VOCAB_PATH=

# Optional — path to directory with bundled vocab and lesson files.
# On first run, loads 120 Spanish words and 12 lessons.
# Point to the data/ directory: BUNDLED_VOCAB_DIR=./data
BUNDLED_VOCAB_DIR=
